<Window x:Class="HeroDrafter.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:HeroDrafter.Views"
        Title="HeroDrafter" Height="800" Width="1400"
        Background="#0A0E17" Foreground="#E0E0E0">
    <Window.Resources>
        <local:IsSlotSelectedConverter x:Key="IsSlotSelectedConverter"/>
        <local:NullToVisibilityConverter x:Key="NullToVis"/>
        <local:SlotBackgroundConverter x:Key="SlotBackgroundConverter"/>
        
        <!-- Gaming Button Style -->
        <Style x:Key="GamingButton" TargetType="Button">
            <Setter Property="Background" Value="#1A1A2E"/>
            <Setter Property="Foreground" Value="#E94560"/>
            <Setter Property="BorderBrush" Value="#E94560"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="12,8"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E94560"/>
                                <Setter Property="Foreground" Value="#0A0E17"/>
                                <Setter Property="BorderBrush" Value="#FF6B6B"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#FF6B6B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Green Gaming Button -->
        <Style x:Key="GreenGamingButton" TargetType="Button" BasedOn="{StaticResource GamingButton}">
            <Setter Property="Background" Value="#1A1A2E"/>
            <Setter Property="Foreground" Value="#00FF88"/>
            <Setter Property="BorderBrush" Value="#00FF88"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#00FF88"/>
                    <Setter Property="Foreground" Value="#0A0E17"/>
                    <Setter Property="BorderBrush" Value="#00FFAA"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Yellow Gaming Button -->
        <Style x:Key="YellowGamingButton" TargetType="Button" BasedOn="{StaticResource GamingButton}">
            <Setter Property="Background" Value="#1A1A2E"/>
            <Setter Property="Foreground" Value="#FFD700"/>
            <Setter Property="BorderBrush" Value="#FFD700"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFD700"/>
                    <Setter Property="Foreground" Value="#0A0E17"/>
                    <Setter Property="BorderBrush" Value="#FFE44D"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Red Gaming Button -->
        <Style x:Key="RedGamingButton" TargetType="Button" BasedOn="{StaticResource GamingButton}">
            <Setter Property="Background" Value="#1A1A2E"/>
            <Setter Property="Foreground" Value="#FF4444"/>
            <Setter Property="BorderBrush" Value="#FF4444"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF4444"/>
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                    <Setter Property="BorderBrush" Value="#FF6666"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Tab Item Style -->
        <Style TargetType="TabItem">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Grid>
                            <Border x:Name="Border" Background="Transparent" BorderBrush="#0F3460" 
                                    BorderThickness="0,0,0,3" Margin="0,0,5,0">
                                <ContentPresenter x:Name="ContentSite" ContentSource="Header" 
                                        HorizontalAlignment="Center" VerticalAlignment="Center"
                                        Margin="20,10"/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#E94560"/>
                                <Setter TargetName="Border" Property="Background" Value="#1A1A2E"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#16213E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Slot Button Style -->
        <Style x:Key="SlotButton" TargetType="Button">
            <Setter Property="Background" Value="#16213E"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#0F3460"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#E94560"/>
                                <Setter TargetName="border" Property="Background" Value="#1A1A2E"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#00FF88"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="4*"/>
        </Grid.ColumnDefinitions>

        <!-- Left: Encyclopedia -->
        <Border Grid.Column="0" BorderBrush="#0F3460" BorderThickness="1" Margin="5" Background="#16213E">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" Margin="10">
                    <TextBlock Text="Енциклопедія Персонажів" FontSize="20" FontWeight="Bold" 
                               VerticalAlignment="Center" Foreground="#E94560"/>
                    <Button Content="⟳" Command="{Binding RefreshCommand}" Width="40" Height="40" Margin="10,0,0,0"
                            Style="{StaticResource GamingButton}" ToolTip="Оновити" FontSize="16"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" Margin="10,5">
                    <Button Content="+ Додати" Command="{Binding AddCharacterCommand}" Width="110" Height="40" Margin="0,0,5,0"
                            Style="{StaticResource GreenGamingButton}" FontSize="13"/>
                    <Button Content="✎ Редагувати" Command="{Binding EditCharacterCommand}" Width="120" Height="40" Margin="0,0,5,0"
                            Style="{StaticResource YellowGamingButton}" FontSize="13"/>
                    <Button Content="✖ Видалити" Command="{Binding DeleteCharacterCommand}" Width="110" Height="40"
                            Style="{StaticResource RedGamingButton}" FontSize="13"/>
                </StackPanel>

                <ListBox ItemsSource="{Binding AllCharacters}" SelectedItem="{Binding SelectedCharacter}"
                         DisplayMemberPath="Name" Background="#0A0E17" Foreground="#E0E0E0" 
                         BorderBrush="#0F3460" Margin="10"/>
                
                <TabControl Margin="10" Background="#0A0E17" BorderBrush="#0F3460" DockPanel.Dock="Top">
                    <TabItem Header="Статистика" Foreground="#E94560">
                        <StackPanel Margin="10">
                            <TextBlock Text="{Binding SelectedCharacter.Name, StringFormat='Назва: {0}'}" FontSize="16" Foreground="#E94560"/>
                            <TextBlock Text="{Binding SelectedCharacter.BasePower, StringFormat='Базова Сила: {0}'}" Margin="0,5,0,0"/>
                            <TextBlock Text="{Binding SelectedCharacter.Rarity, StringFormat='Рідкість: {0}'}"/>
                            <TextBlock Text="{Binding SelectedCharacter.PrimaryRole, StringFormat='Основна Роль: {0}'}"/>
                        </StackPanel>
                    </TabItem>
                    <TabItem Header="Здібності" Foreground="#E94560">
                        <StackPanel Margin="10">
                            <TextBlock Text="Навичка:" FontWeight="Bold" Foreground="#00FF88"/>
                            <TextBlock Text="{Binding SelectedCharacter.Skill}" TextWrapping="Wrap" Margin="0,5,0,10"/>
                            <TextBlock Text="Ульта:" FontWeight="Bold" Foreground="#00FF88" Margin="0,10,0,0"/>
                            <TextBlock Text="{Binding SelectedCharacter.Ultimate}" TextWrapping="Wrap"/>
                        </StackPanel>
                    </TabItem>
                    <TabItem Header="Історія" Foreground="#E94560">
                        <ScrollViewer Margin="10">
                            <TextBlock Text="{Binding SelectedCharacter.Lore}" TextWrapping="Wrap"/>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>
            </DockPanel>
        </Border>

        <!-- Right: Squad Optimizer -->
        <Border Grid.Column="1" BorderBrush="#0F3460" BorderThickness="1" Margin="5" Background="#16213E">
            <DockPanel>
                <!-- Allies -->
                <Border DockPanel.Dock="Top" BorderBrush="#00FF88" BorderThickness="1" Margin="10" Padding="10" Background="#0A0E17">
                    <StackPanel>
                        <TextBlock Text="⚔ СОЮЗНИКИ" FontSize="18" FontWeight="Bold" Foreground="#00FF88" Margin="0,0,0,10"/>
                        <StackPanel Orientation="Horizontal">
                            <Button Command="{Binding SelectAllySlotCommand}" CommandParameter="0" 
                                    Style="{StaticResource SlotButton}" Width="150" Height="80" Margin="5">
                                <Button.Content>
                                    <StackPanel>
                                        <TextBlock Text="{Binding AllySlots[0].Name, FallbackValue='Порожньо'}" 
                                                   HorizontalAlignment="Center" FontWeight="Bold" FontSize="13"/>
                                        <TextBlock Text="{Binding AllySlots[0].BasePower, StringFormat='Сила: {0}'}" 
                                                   HorizontalAlignment="Center" FontSize="12" Foreground="#00FF88"
                                                   Visibility="{Binding AllySlots[0], Converter={StaticResource NullToVis}}"/>
                                    </StackPanel>
                                </Button.Content>
                                <Button.Background>
                                    <MultiBinding Converter="{StaticResource SlotBackgroundConverter}">
                                        <Binding Path="SelectedAllySlot" />
                                        <Binding>
                                            <Binding.Source>0</Binding.Source>
                                        </Binding>
                                    </MultiBinding>
                                </Button.Background>
                            </Button>
                            <Button Command="{Binding SelectAllySlotCommand}" CommandParameter="1"
                                    Style="{StaticResource SlotButton}" Width="150" Height="80" Margin="5">
                                <Button.Content>
                                    <StackPanel>
                                        <TextBlock Text="{Binding AllySlots[1].Name, FallbackValue='Порожньо'}" 
                                                   HorizontalAlignment="Center" FontWeight="Bold" FontSize="13"/>
                                        <TextBlock Text="{Binding AllySlots[1].BasePower, StringFormat='Сила: {0}'}" 
                                                   HorizontalAlignment="Center" FontSize="12" Foreground="#00FF88"
                                                   Visibility="{Binding AllySlots[1], Converter={StaticResource NullToVis}}"/>
                                    </StackPanel>
                                </Button.Content>
                                <Button.Background>
                                    <MultiBinding Converter="{StaticResource SlotBackgroundConverter}">
                                        <Binding Path="SelectedAllySlot" />
                                        <Binding>
                                            <Binding.Source>1</Binding.Source>
                                        </Binding>
                                    </MultiBinding>
                                </Button.Background>
                            </Button>
                            <Button Command="{Binding SelectAllySlotCommand}" CommandParameter="2"
                                    Style="{StaticResource SlotButton}" Width="150" Height="80" Margin="5">
                                <Button.Content>
                                    <StackPanel>
                                        <TextBlock Text="{Binding AllySlots[2].Name, FallbackValue='Порожньо'}" 
                                                   HorizontalAlignment="Center" FontWeight="Bold" FontSize="13"/>
                                        <TextBlock Text="{Binding AllySlots[2].BasePower, StringFormat='Сила: {0}'}" 
                                                   HorizontalAlignment="Center" FontSize="12" Foreground="#00FF88"
                                                   Visibility="{Binding AllySlots[2], Converter={StaticResource NullToVis}}"/>
                                    </StackPanel>
                                </Button.Content>
                                <Button.Background>
                                    <MultiBinding Converter="{StaticResource SlotBackgroundConverter}">
                                        <Binding Path="SelectedAllySlot" />
                                        <Binding>
                                            <Binding.Source>2</Binding.Source>
                                        </Binding>
                                    </MultiBinding>
                                </Button.Background>
                            </Button>
                        </StackPanel>
                        <Button Content="🗑 Видалити з вибраного" Command="{Binding RemoveSelectedAllyCommand}" 
                                Style="{StaticResource RedGamingButton}" Width="220" Height="35" Margin="0,10,0,0"
                                HorizontalAlignment="Left" FontSize="12"/>
                    </StackPanel>
                </Border>

                <Button Content="➕ Додати в Союзники" Command="{Binding AssignAllyCommand}" 
                        Style="{StaticResource GreenGamingButton}" DockPanel.Dock="Top" 
                        Margin="10,5,10,5" HorizontalAlignment="Left" Width="220" Height="45" FontSize="14"/>

                <!-- Enemies -->
                <Border DockPanel.Dock="Top" BorderBrush="#E94560" BorderThickness="1" Margin="10" Padding="10" Background="#0A0E17">
                    <StackPanel>
                        <TextBlock Text="☠ ВОРОГИ" FontSize="18" FontWeight="Bold" Foreground="#E94560" Margin="0,0,0,10"/>
                        <StackPanel Orientation="Horizontal">
                            <Button Command="{Binding SelectEnemySlotCommand}" CommandParameter="0"
                                    Style="{StaticResource SlotButton}" Width="150" Height="80" Margin="5">
                                <Button.Content>
                                    <StackPanel>
                                        <TextBlock Text="{Binding EnemySlots[0].Name, FallbackValue='Порожньо'}" 
                                                   HorizontalAlignment="Center" FontWeight="Bold" FontSize="13"/>
                                        <TextBlock Text="{Binding EnemySlots[0].BasePower, StringFormat='Сила: {0}'}" 
                                                   HorizontalAlignment="Center" FontSize="12" Foreground="#E94560"
                                                   Visibility="{Binding EnemySlots[0], Converter={StaticResource NullToVis}}"/>
                                    </StackPanel>
                                </Button.Content>
                                <Button.Background>
                                    <MultiBinding Converter="{StaticResource SlotBackgroundConverter}">
                                        <Binding Path="SelectedEnemySlot" />
                                        <Binding>
                                            <Binding.Source>0</Binding.Source>
                                        </Binding>
                                    </MultiBinding>
                                </Button.Background>
                            </Button>
                            <Button Command="{Binding SelectEnemySlotCommand}" CommandParameter="1"
                                    Style="{StaticResource SlotButton}" Width="150" Height="80" Margin="5">
                                <Button.Content>
                                    <StackPanel>
                                        <TextBlock Text="{Binding EnemySlots[1].Name, FallbackValue='Порожньо'}" 
                                                   HorizontalAlignment="Center" FontWeight="Bold" FontSize="13"/>
                                        <TextBlock Text="{Binding EnemySlots[1].BasePower, StringFormat='Сила: {0}'}" 
                                                   HorizontalAlignment="Center" FontSize="12" Foreground="#E94560"
                                                   Visibility="{Binding EnemySlots[1], Converter={StaticResource NullToVis}}"/>
                                    </StackPanel>
                                </Button.Content>
                                <Button.Background>
                                    <MultiBinding Converter="{StaticResource SlotBackgroundConverter}">
                                        <Binding Path="SelectedEnemySlot" />
                                        <Binding>
                                            <Binding.Source>1</Binding.Source>
                                        </Binding>
                                    </MultiBinding>
                                </Button.Background>
                            </Button>
                            <Button Command="{Binding SelectEnemySlotCommand}" CommandParameter="2"
                                    Style="{StaticResource SlotButton}" Width="150" Height="80" Margin="5">
                                <Button.Content>
                                    <StackPanel>
                                        <TextBlock Text="{Binding EnemySlots[2].Name, FallbackValue='Порожньо'}" 
                                                   HorizontalAlignment="Center" FontWeight="Bold" FontSize="13"/>
                                        <TextBlock Text="{Binding EnemySlots[2].BasePower, StringFormat='Сила: {0}'}" 
                                                   HorizontalAlignment="Center" FontSize="12" Foreground="#E94560"
                                                   Visibility="{Binding EnemySlots[2], Converter={StaticResource NullToVis}}"/>
                                    </StackPanel>
                                </Button.Content>
                                <Button.Background>
                                    <MultiBinding Converter="{StaticResource SlotBackgroundConverter}">
                                        <Binding Path="SelectedEnemySlot" />
                                        <Binding>
                                            <Binding.Source>2</Binding.Source>
                                        </Binding>
                                    </MultiBinding>
                                </Button.Background>
                            </Button>
                        </StackPanel>
                        <Button Content="🗑 Видалити з вибраного" Command="{Binding RemoveSelectedEnemyCommand}" 
                                Style="{StaticResource RedGamingButton}" Width="220" Height="35" Margin="0,10,0,0"
                                HorizontalAlignment="Left" FontSize="12"/>
                    </StackPanel>
                </Border>

                <Button Content="➕ Додати у Вороги" Command="{Binding AssignEnemyCommand}" 
                        Style="{StaticResource RedGamingButton}" DockPanel.Dock="Top" 
                        Margin="10,5,10,5" HorizontalAlignment="Left" Width="220" Height="45" FontSize="14"/>

                <!-- Analytics -->
                <Border BorderBrush="#0F3460" BorderThickness="1" Margin="10" Padding="10" Background="#0A0E17">
                    <StackPanel>
                        <TextBlock Text="📊 АНАЛІТИКА" FontSize="18" FontWeight="Bold" Foreground="#FFD700" Margin="0,0,0,10"/>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- Allies Stats -->
                            <StackPanel Grid.Column="0" Margin="5">
                                <TextBlock Text="СОЮЗНИКИ" FontWeight="Bold" Foreground="#00FF88" FontSize="13"/>
                                <TextBlock Text="{Binding TotalBasePower, StringFormat='📊 База: {0}'}" Margin="0,5,0,0">
                                    <TextBlock.ToolTip>
                                        <ToolTip Content="Сума базової сили всіх героїв команди.&#x0a;&#x0a;Формула: Σ BasePower кожного героя.&#x0a;Базова сила — це початкова потужність героя, що визначає його потенціал у бою." MaxWidth="220" TextElement.FontSize="12" Background="#1A1A2E" Foreground="#E0E0E0" BorderBrush="#0F3460"/>
                                    </TextBlock.ToolTip>
                                </TextBlock>
                                <TextBlock Text="{Binding BalanceBonus, StringFormat='⚖️ Баланс: {0}'}">
                                    <TextBlock.ToolTip>
                                        <ToolTip MaxWidth="260" TextElement.FontSize="12" Background="#1A1A2E" Foreground="#E0E0E0" BorderBrush="#0F3460">
                                            <TextBlock TextWrapping="Wrap">Оцінка збалансованості команди за ролями.&#x0a;&#x0a;• Повний набір (танк+підтримка+дамагер): +25&#x0a;• Частковий набір: +10&#x0a;• Немає танка і підтримки: -20&#x0a;• Наявність танка: +5, підтримки: +5, вбивці: +3&#x0a;• Синергія танк+підтримка: +8&#x0a;• 2+ вбивці: -8, 2+ мага: -5</TextBlock>
                                        </ToolTip>
                                    </TextBlock.ToolTip>
                                </TextBlock>
                                <TextBlock Text="{Binding CounterPickBonus, StringFormat='🎯 Контр-піки: {0}'}">
                                    <TextBlock.ToolTip>
                                        <ToolTip MaxWidth="260" TextElement.FontSize="12" Background="#1A1A2E" Foreground="#E0E0E0" BorderBrush="#0F3460">
                                            <TextBlock TextWrapping="Wrap">Бонуси за контрпіки ворожих героїв.&#x0a;&#x0a;• Вбивця → Підтримка/Маг: +12&#x0a;• Танк/Гібрид → Вбивця: +12&#x0a;• Стрілець/Маг → Танк: +12&#x0a;• Підтримка → Маг: +8&#x0a;• Вбивця vs Вбивця: -5</TextBlock>
                                        </ToolTip>
                                    </TextBlock.ToolTip>
                                </TextBlock>
                                <TextBlock Text="{Binding RarityBonus, StringFormat='💎 Рідкість: {0}'}">
                                    <TextBlock.ToolTip>
                                        <ToolTip MaxWidth="260" TextElement.FontSize="12" Background="#1A1A2E" Foreground="#E0E0E0" BorderBrush="#0F3460">
                                            <TextBlock TextWrapping="Wrap">Бонуси за рідкість героїв.&#x0a;&#x0a;• Звичайний: 0&#x0a;• Рідкісний: +5&#x0a;• Епічний: +10&#x0a;• Легендарний: +18&#x0a;• Королівський: +25&#x0a;&#x0a;Сума бонусів усіх героїв команди.</TextBlock>
                                        </ToolTip>
                                    </TextBlock.ToolTip>
                                </TextBlock>
                                <TextBlock Text="{Binding AllyEnergyBonus, StringFormat='⚡ Енергії: {0}'}">
                                    <TextBlock.ToolTip>
                                        <ToolTip MaxWidth="260" TextElement.FontSize="12" Background="#1A1A2E" Foreground="#E0E0E0" BorderBrush="#0F3460">
                                            <TextBlock TextWrapping="Wrap">Бонус за різноманітність типів енергії в команді.&#x0a;&#x0a;• 2+ різних типи: +5 + к-сть типів×2&#x0a;• 3+ типи: додатково +5&#x0a;• 4+ типи: додатково +5&#x0a;&#x0a;Заохочує різноманітність енергій для гнучкості в бою.</TextBlock>
                                        </ToolTip>
                                    </TextBlock.ToolTip>
                                </TextBlock>
                                <TextBlock Text="{Binding AllyRolePenalty, StringFormat='⚠️ Штрафи: {0}'}">
                                    <TextBlock.ToolTip>
                                        <ToolTip MaxWidth="260" TextElement.FontSize="12" Background="#1A1A2E" Foreground="#E0E0E0" BorderBrush="#0F3460">
                                            <TextBlock TextWrapping="Wrap">Штрафи за відсутність ключових ролей.&#x0a;&#x0a;• Немає танка (включно з гібридом): -15&#x0a;• Немає підтримки: -10&#x0a;• Немає дамагера (маг/стрілець/вбивця): -20</TextBlock>
                                        </ToolTip>
                                    </TextBlock.ToolTip>
                                </TextBlock>
                                <TextBlock Text="{Binding TotalEfficiency, StringFormat='🏆 РАЗОМ: {0}'}" 
                                           FontSize="14" FontWeight="Bold" Foreground="#00FF88" Margin="0,5,0,0">
                                    <TextBlock.ToolTip>
                                        <ToolTip MaxWidth="260" TextElement.FontSize="12" Background="#1A1A2E" Foreground="#E0E0E0" BorderBrush="#0F3460">
                                            <TextBlock TextWrapping="Wrap">Загальна ефективність команди.&#x0a;&#x0a;Формула: База + Баланс + Контр-піки + Рідкість + Енергії + Штрафи&#x0a;&#x0a;Чим вище значення, тим теоретично сильніша команда.</TextBlock>
                                        </ToolTip>
                                    </TextBlock.ToolTip>
                                </TextBlock>
                                <TextBlock Text="{Binding AllyRoleDist, StringFormat='👤 Склад: {0}'}" 
                                           FontSize="11" TextWrapping="Wrap" Margin="0,3,0,0">
                                    <TextBlock.ToolTip>
                                        <ToolTip Content="Розподіл ролей у команді. Показує, скільки героїв якої ролі присутньо." MaxWidth="220" TextElement.FontSize="12" Background="#1A1A2E" Foreground="#E0E0E0" BorderBrush="#0F3460"/>
                                    </TextBlock.ToolTip>
                                </TextBlock>
                            </StackPanel>
                            
                            <!-- Enemies Stats -->
                            <StackPanel Grid.Column="1" Margin="5">
                                <TextBlock Text="ВОРОГИ" FontWeight="Bold" Foreground="#E94560" FontSize="13"/>
                                <TextBlock Text="{Binding EnemyTotalBasePower, StringFormat='📊 База: {0}'}" Margin="0,5,0,0">
                                    <TextBlock.ToolTip>
                                        <ToolTip Content="Сума базової сили всіх героїв команди.&#x0a;&#x0a;Формула: Σ BasePower кожного героя.&#x0a;Базова сила — це початкова потужність героя, що визначає його потенціал у бою." MaxWidth="220" TextElement.FontSize="12" Background="#1A1A2E" Foreground="#E0E0E0" BorderBrush="#0F3460"/>
                                    </TextBlock.ToolTip>
                                </TextBlock>
                                <TextBlock Text="{Binding EnemyBalanceBonus, StringFormat='⚖️ Баланс: {0}'}">
                                    <TextBlock.ToolTip>
                                        <ToolTip MaxWidth="260" TextElement.FontSize="12" Background="#1A1A2E" Foreground="#E0E0E0" BorderBrush="#0F3460">
                                            <TextBlock TextWrapping="Wrap">Оцінка збалансованості команди за ролями.&#x0a;&#x0a;• Повний набір (танк+підтримка+дамагер): +25&#x0a;• Частковий набір: +10&#x0a;• Немає танка і підтримки: -20&#x0a;• Наявність танка: +5, підтримки: +5, вбивці: +3&#x0a;• Синергія танк+підтримка: +8&#x0a;• 2+ вбивці: -8, 2+ мага: -5</TextBlock>
                                        </ToolTip>
                                    </TextBlock.ToolTip>
                                </TextBlock>
                                <TextBlock Text="{Binding EnemyCounterPickBonus, StringFormat='🎯 Контр-піки: {0}'}">
                                    <TextBlock.ToolTip>
                                        <ToolTip MaxWidth="260" TextElement.FontSize="12" Background="#1A1A2E" Foreground="#E0E0E0" BorderBrush="#0F3460">
                                            <TextBlock TextWrapping="Wrap">Бонуси за контрпіки ворожих героїв.&#x0a;&#x0a;• Вбивця → Підтримка/Маг: +12&#x0a;• Танк/Гібрид → Вбивця: +12&#x0a;• Стрілець/Маг → Танк: +12&#x0a;• Підтримка → Маг: +8&#x0a;• Вбивця vs Вбивця: -5</TextBlock>
                                        </ToolTip>
                                    </TextBlock.ToolTip>
                                </TextBlock>
                                <TextBlock Text="{Binding EnemyRarityBonus, StringFormat='💎 Рідкість: {0}'}">
                                    <TextBlock.ToolTip>
                                        <ToolTip MaxWidth="260" TextElement.FontSize="12" Background="#1A1A2E" Foreground="#E0E0E0" BorderBrush="#0F3460">
                                            <TextBlock TextWrapping="Wrap">Бонуси за рідкість героїв.&#x0a;&#x0a;• Звичайний: 0&#x0a;• Рідкісний: +5&#x0a;• Епічний: +10&#x0a;• Легендарний: +18&#x0a;• Королівський: +25&#x0a;&#x0a;Сума бонусів усіх героїв команди.</TextBlock>
                                        </ToolTip>
                                    </TextBlock.ToolTip>
                                </TextBlock>
                                <TextBlock Text="{Binding EnemyEnergyBonus, StringFormat='⚡ Енергії: {0}'}">
                                    <TextBlock.ToolTip>
                                        <ToolTip MaxWidth="260" TextElement.FontSize="12" Background="#1A1A2E" Foreground="#E0E0E0" BorderBrush="#0F3460">
                                            <TextBlock TextWrapping="Wrap">Бонус за різноманітність типів енергії в команді.&#x0a;&#x0a;• 2+ різних типи: +5 + к-сть типів×2&#x0a;• 3+ типи: додатково +5&#x0a;• 4+ типи: додатково +5&#x0a;&#x0a;Заохочує різноманітність енергій для гнучкості в бою.</TextBlock>
                                        </ToolTip>
                                    </TextBlock.ToolTip>
                                </TextBlock>
                                <TextBlock Text="{Binding EnemyRolePenalty, StringFormat='⚠️ Штрафи: {0}'}">
                                    <TextBlock.ToolTip>
                                        <ToolTip MaxWidth="260" TextElement.FontSize="12" Background="#1A1A2E" Foreground="#E0E0E0" BorderBrush="#0F3460">
                                            <TextBlock TextWrapping="Wrap">Штрафи за відсутність ключових ролей.&#x0a;&#x0a;• Немає танка (включно з гібридом): -15&#x0a;• Немає підтримки: -10&#x0a;• Немає дамагера (маг/стрілець/вбивця): -20</TextBlock>
                                        </ToolTip>
                                    </TextBlock.ToolTip>
                                </TextBlock>
                                <TextBlock Text="{Binding EnemyTotalEfficiency, StringFormat='🏆 РАЗОМ: {0}'}" 
                                           FontSize="14" FontWeight="Bold" Foreground="#E94560" Margin="0,5,0,0">
                                    <TextBlock.ToolTip>
                                        <ToolTip MaxWidth="260" TextElement.FontSize="12" Background="#1A1A2E" Foreground="#E0E0E0" BorderBrush="#0F3460">
                                            <TextBlock TextWrapping="Wrap">Загальна ефективність команди.&#x0a;&#x0a;Формула: База + Баланс + Контр-піки + Рідкість + Енергії + Штрафи&#x0a;&#x0a;Чим вище значення, тим теоретично сильніша команда.</TextBlock>
                                        </ToolTip>
                                    </TextBlock.ToolTip>
                                </TextBlock>
                                <TextBlock Text="{Binding EnemyRoleDist, StringFormat='👤 Склад: {0}'}" 
                                           FontSize="11" TextWrapping="Wrap" Margin="0,3,0,0">
                                    <TextBlock.ToolTip>
                                        <ToolTip Content="Розподіл ролей у команді. Показує, скільки героїв якої ролі присутньо." MaxWidth="220" TextElement.FontSize="12" Background="#1A1A2E" Foreground="#E0E0E0" BorderBrush="#0F3460"/>
                                    </TextBlock.ToolTip>
                                </TextBlock>
                            </StackPanel>
                        </Grid>
                        
                        <Separator Margin="0,10" Background="#0F3460"/>
                        
                        <TextBlock Text="{Binding StrongerParty, StringFormat='🏆 ТЕОРЕТИЧНО СИЛЬНІША: {0}'}" 
                                   FontSize="16" FontWeight="Bold" Foreground="#FFD700" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Button Content="📄 Експорт звіту" Command="{Binding ExportReportCommand}" 
                        Style="{StaticResource YellowGamingButton}" DockPanel.Dock="Bottom" 
                        Margin="10" HorizontalAlignment="Right" Width="200" Height="40" FontSize="13"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>