<Window x:Class="HeroDrafter.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HeroDrafter" Height="800" Width="1200"
        Background="#1E1E1E" Foreground="#FFFFFF">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>

        <!-- Left: Encyclopedia -->
        <Border Grid.Column="0" BorderBrush="#444" BorderThickness="1" Margin="5">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" Margin="10">
                    <TextBlock Text="Енциклопедія Персонажів" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                    <Button Content="+" Command="{Binding RefreshCommand}" Width="30" Height="30" Margin="10,0,0,0"
                            Background="#0078D4" Foreground="#FFF" ToolTip="Оновити"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" Margin="10,0">
                    <Button Content="Додати" Command="{Binding AddCharacterCommand}" Width="80" Height="30" Margin="0,0,5,0"
                            Background="#28A745" Foreground="#FFF"/>
                    <Button Content="Редагувати" Command="{Binding EditCharacterCommand}" Width="90" Height="30" Margin="0,0,5,0"
                            Background="#FFC107" Foreground="#000"/>
                    <Button Content="Видалити" Command="{Binding DeleteCharacterCommand}" Width="80" Height="30"
                            Background="#DC3545" Foreground="#FFF"/>
                </StackPanel>
                <ListBox ItemsSource="{Binding AllCharacters}" SelectedItem="{Binding SelectedCharacter}"
                         DisplayMemberPath="Name" Background="#252525" Foreground="#FFF" Margin="10"/>
                
                <TabControl Margin="10" Background="#252525" BorderBrush="#444" DockPanel.Dock="Top">
                    <TabItem Header="Статистика" Foreground="#FFF">
                        <StackPanel Margin="10">
                            <TextBlock Text="{Binding SelectedCharacter.Name, StringFormat='Назва: {0}'}" FontSize="16"/>
                            <TextBlock Text="{Binding SelectedCharacter.BasePower, StringFormat='Базова Сила: {0}'}"/>
                            <TextBlock Text="{Binding SelectedCharacter.Rarity, StringFormat='Рідкість: {0}'}"/>
                            <TextBlock Text="{Binding SelectedCharacter.PrimaryRole, StringFormat='Основна Роль: {0}'}"/>
                        </StackPanel>
                    </TabItem>
                    <TabItem Header="Здібності" Foreground="#FFF">
                        <StackPanel Margin="10">
                            <TextBlock Text="Навичка:" FontWeight="Bold"/>
                            <TextBlock Text="{Binding SelectedCharacter.Skill}" TextWrapping="Wrap"/>
                            <TextBlock Text="Ульта:" FontWeight="Bold" Margin="0,10,0,0"/>
                            <TextBlock Text="{Binding SelectedCharacter.Ultimate}" TextWrapping="Wrap"/>
                        </StackPanel>
                    </TabItem>
                    <TabItem Header="Лор" Foreground="#FFF">
                        <ScrollViewer Margin="10">
                            <TextBlock Text="{Binding SelectedCharacter.Lore}" TextWrapping="Wrap"/>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>
            </DockPanel>
        </Border>

        <!-- Right: Squad Optimizer -->
        <Border Grid.Column="1" BorderBrush="#444" BorderThickness="1" Margin="5">
            <DockPanel>
                <GroupBox Header="Союзники" Foreground="#FFF" Margin="10" DockPanel.Dock="Top">
                    <StackPanel Orientation="Horizontal">
                        <Button Content="{Binding AllySlots[0].Name, FallbackValue='Порожньо'}" Width="120" Height="60" Margin="5"
                                Command="{Binding ClearAllyCommand}" CommandParameter="0"/>
                        <Button Content="{Binding AllySlots[1].Name, FallbackValue='Порожньо'}" Width="120" Height="60" Margin="5"
                                Command="{Binding ClearAllyCommand}" CommandParameter="1"/>
                        <Button Content="{Binding AllySlots[2].Name, FallbackValue='Порожньо'}" Width="120" Height="60" Margin="5"
                                Command="{Binding ClearAllyCommand}" CommandParameter="2"/>
                    </StackPanel>
                </GroupBox>

                <Button Content="Додати в Союзники" Command="{Binding AssignAllyCommand}" DockPanel.Dock="Top" Margin="10" HorizontalAlignment="Left"/>

                <GroupBox Header="Вороги" Foreground="#FFF" Margin="10" DockPanel.Dock="Top">
                    <StackPanel Orientation="Horizontal">
                        <Button Content="{Binding EnemySlots[0].Name, FallbackValue='Порожньо'}" Width="120" Height="60" Margin="5"
                                Command="{Binding ClearEnemyCommand}" CommandParameter="0"/>
                        <Button Content="{Binding EnemySlots[1].Name, FallbackValue='Порожньо'}" Width="120" Height="60" Margin="5"
                                Command="{Binding ClearEnemyCommand}" CommandParameter="1"/>
                        <Button Content="{Binding EnemySlots[2].Name, FallbackValue='Порожньо'}" Width="120" Height="60" Margin="5"
                                Command="{Binding ClearEnemyCommand}" CommandParameter="2"/>
                    </StackPanel>
                </GroupBox>

                <Button Content="Додати у Вороги" Command="{Binding AssignEnemyCommand}" DockPanel.Dock="Top" Margin="10" HorizontalAlignment="Left"/>

                <GroupBox Header="Аналітична Панель" Foreground="#FFF" Margin="10" DockPanel.Dock="Top">
                    <StackPanel Margin="10">
                        <TextBlock Text="{Binding TotalBasePower, StringFormat='Базова сила союзників: {0}'}"/>
                        <TextBlock Text="{Binding BalanceBonus, StringFormat='Бонус за баланс складу: {0}'}"/>
                        <TextBlock Text="{Binding CounterPickBonus, StringFormat='Тактична перевага (Контр-піки): {0}'}"/>
                        <TextBlock Text="{Binding RarityBonus, StringFormat='Бонус рідкості: {0}'}"/>
                        <TextBlock Text="{Binding TotalEfficiency, StringFormat='ЗАГАЛЬНА ЕФЕКТИВНІСТЬ: {0}'}" 
                                   FontSize="16" FontWeight="Bold" Margin="0,10,0,0"/>
                    </StackPanel>
                </GroupBox>

                <Button Content="Експорт звіту" Command="{Binding ExportReportCommand}" DockPanel.Dock="Bottom" Margin="10" HorizontalAlignment="Right"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
