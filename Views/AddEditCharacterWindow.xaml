<Window x:Class="HeroDrafter.Views.AddEditCharacterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Додати/Редагувати Персонажа" Height="700" Width="800"
        Background="#1E1E1E" Foreground="#FFFFFF"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="{Binding WindowTitle}" FontSize="24" FontWeight="Bold" Margin="0,0,0,15"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Назва" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" 
                             Background="#2D2D2D" Foreground="#FFF" BorderBrush="#555" Padding="5" Margin="0,0,0,10"/>

                    <TextBlock Text="Рідкість" FontWeight="Bold" Margin="0,0,0,5"/>
                    <ComboBox ItemsSource="{Binding AllRarities}" SelectedItem="{Binding SelectedRarity}"
                             Background="#2D2D2D" Foreground="#FFF" BorderBrush="#555" Padding="5" Margin="0,0,0,10">
                        <ComboBox.ItemContainerStyle>
                            <Style TargetType="ComboBoxItem">
                                <Setter Property="Background" Value="#2D2D2D"/>
                                <Setter Property="Foreground" Value="#FFF"/>
                            </Style>
                        </ComboBox.ItemContainerStyle>
                    </ComboBox>

                    <TextBlock Text="Основна Роль" FontWeight="Bold" Margin="0,0,0,5"/>
                    <ComboBox ItemsSource="{Binding AllRoles}" SelectedItem="{Binding SelectedRole}"
                             Background="#2D2D2D" Foreground="#FFF" BorderBrush="#555" Padding="5" Margin="0,0,0,10">
                        <ComboBox.ItemContainerStyle>
                            <Style TargetType="ComboBoxItem">
                                <Setter Property="Background" Value="#2D2D2D"/>
                                <Setter Property="Foreground" Value="#FFF"/>
                            </Style>
                        </ComboBox.ItemContainerStyle>
                    </ComboBox>

                    <TextBlock Text="Базова Сила" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding BasePower, UpdateSourceTrigger=PropertyChanged}" 
                             Background="#2D2D2D" Foreground="#FFF" BorderBrush="#555" Padding="5" Margin="0,0,0,10"/>

                    <TextBlock Text="Стилі Бою (кома між)" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding CombatStylesText, UpdateSourceTrigger=PropertyChanged}" 
                             Background="#2D2D2D" Foreground="#FFF" BorderBrush="#555" Padding="5" Margin="0,0,0,10"/>

                    <TextBlock Text="Енергії (кома між)" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding EnergiesText, UpdateSourceTrigger=PropertyChanged}" 
                             Background="#2D2D2D" Foreground="#FFF" BorderBrush="#555" Padding="5" Margin="0,0,0,10"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Навичка (Прийом)" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding Skill, UpdateSourceTrigger=PropertyChanged}" 
                             Background="#2D2D2D" Foreground="#FFF" BorderBrush="#555" 
                             Padding="5" TextWrapping="Wrap" AcceptsReturn="True" 
                             Height="80" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10"/>

                    <TextBlock Text="Суперприйом" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding Ultimate, UpdateSourceTrigger=PropertyChanged}" 
                             Background="#2D2D2D" Foreground="#FFF" BorderBrush="#555" 
                             Padding="5" TextWrapping="Wrap" AcceptsReturn="True" 
                             Height="80" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10"/>

                    <TextBlock Text="Короткий Опис" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding ShortDescription, UpdateSourceTrigger=PropertyChanged}" 
                             Background="#2D2D2D" Foreground="#FFF" BorderBrush="#555" 
                             Padding="5" TextWrapping="Wrap" AcceptsReturn="True" 
                             Height="60" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10"/>

                    <TextBlock Text="Лор (Історія)" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding Lore, UpdateSourceTrigger=PropertyChanged}" 
                             Background="#2D2D2D" Foreground="#FFF" BorderBrush="#555" 
                             Padding="5" TextWrapping="Wrap" AcceptsReturn="True" 
                             Height="100" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10"/>

                    <TextBlock Text="Пасивні Здібності (кома між, 0+)" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding PassivesText, UpdateSourceTrigger=PropertyChanged}" 
                             Background="#2D2D2D" Foreground="#FFF" BorderBrush="#555" 
                             Padding="5" TextWrapping="Wrap" AcceptsReturn="True" 
                             Height="80" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10"/>
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Скасувати" Command="{Binding CancelCommand}" Width="100" Margin="0,0,10,0"
                    Background="#444" Foreground="#FFF" Padding="10,5"/>
            <Button Content="Зберегти" Command="{Binding SaveCommand}" Width="100"
                    Background="#0078D4" Foreground="#FFF" Padding="10,5"/>
        </StackPanel>
    </Grid>
</Window>